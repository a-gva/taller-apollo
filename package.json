{
  "name": "@inspec-smart/api-apollo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Dummy Apollo GraphQL server with SQLite + Drizzle migrations.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "node ../node_modules/typescript/bin/tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "client": "tsx src/client.ts",
    "client:subscribe": "tsx src/subscription-client.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@apollo/server": "^4.12.2",
    "@graphql-tools/schema": "^10.0.29",
    "@libsql/client": "^0.15.15",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.2",
    "express": "^4.21.2",
    "graphql": "^16.10.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^5.16.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.23",
    "@types/node": "^22.13.14",
    "@types/ws": "^8.5.16",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.3",
    "vitest": "^3.2.4",
    "zod": "4.3.6"
  }
}
